# Token de System User da Meta (não expira)
META_ACCESS_TOKEN=EAAG...

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Google Ads (OAuth de usuário único + MCC, IDs sem hífens)
GOOGLE_ADS_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=GOCSPX-xxxx
GOOGLE_ADS_REFRESH_TOKEN=1//xxxx
GOOGLE_ADS_DEVELOPER_TOKEN=xxxx
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890

# Segredo para proteger a rota de coleta (o Vercel Cron usa como Bearer)
CRON_SECRET=gere-uma-string-aleatoria-aqui

# Acesso pessoal ao dashboard (também configure na Vercel)
# Use uma senha forte (mín. 12 caracteres) e um segredo aleatório (mín. 32).
DASHBOARD_PASSWORD=troque-por-uma-senha-forte
SESSION_SECRET=gere-uma-string-aleatoria-com-32-ou-mais-caracteres
